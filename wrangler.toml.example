name = "baiqi-cf-worker-mihomo"
main = "worker.js"
compatibility_date = "2024-12-01"

kv_namespaces = [
  { binding = "KV", id = "replace-with-your-kv-namespace-id" }
]

[vars]
UUID = "replace-with-your-vless-uuid"
ADMIN = "replace-with-your-admin-password"
KEY = "replace-with-your-admin-password"
NEW_IP = "true"
